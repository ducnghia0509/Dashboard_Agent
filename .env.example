# Copy sang .env va dien gia tri that. KHONG commit .env.

# Postgres ghi (dung cho luong ingest: import_execute). Trung voi DashBoard_AI/.env.
DATABASE_URL=postgresql://user:password@host:5432/tc_dashboard

# Postgres READ-ONLY (dung cho luong qa: sql_query). Tao bang sql/create_ro_role.sql
# truoc, roi dien connection string cua role read-only vao day. KHONG duoc trung
# voi DATABASE_URL o tren.
DATABASE_URL_RO=postgresql://dashboard_qa_ro:password@host:5432/tc_dashboard

# Duong dan toi backend/app cua DashBoard_AI (be_bridge.py se sys.path.insert vao day).
BACKEND_PATH=../DashBoard_AI/backend

# Thu muc chua file xlsx dau vao (analyst doc de phan tich template; qa doc de source_inspect).
# Mac dinh tro sang thu muc du lieu mau da co san.
INPUT_DIR=../Data_test_dashboard

# Gioi han an toan cho sql_query (guardrails.py).
SQL_DEFAULT_LIMIT=500
SQL_MAX_LIMIT=2000
SQL_STATEMENT_TIMEOUT_MS=5000

# 9Router - endpoint OpenAI-compatible dung chung cho moi model cua moi subagent
# (xem README.md "Kien truc 2 tang"). CHUA trien khai - dien khi 9Router chay that.
OPENCLAW_MODEL_BASE_URL=http://localhost:20128/v1
